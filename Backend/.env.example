# KidsBuddy Backend Configuration

HOST=0.0.0.0
PORT=8000

# CORS Allowed Origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:3007

# LLM Provider to use
# Supported options: gemini, openai, claude, deepseek, ollama, mock
LLM_PROVIDER=gemini

# --- API Keys (fill in the ones you use) ---
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- Model Selection ---
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_MODEL=gpt-5.4-nano
CLAUDE_MODEL=claude-haiku-4-5
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Ollama / Local LLM Settings ---
OLLAMA_API_BASE=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# --- Hugging Face Local LLM Override ---
# If a Hugging Face model identifier is provided here (e.g. google/gemma-4-E2B),
# it will override LLM_PROVIDER to 'huggingface' and use it for remote inference.
HUGGINGFACE_LOCAL_MODEL=
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
